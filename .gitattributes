# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# Explicit text files
*.ts         text eol=lf
*.js         text eol=lf
*.json       text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.svg        text eol=lf

# Binary files (no conversion)
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
